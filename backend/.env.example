DATABASE_URL=sqlite:///./app.db
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# JSON-encoded fallback model list used when Gemini returns retryable
# 429/500/503/504 errors for the primary model.
GEMINI_FALLBACK_MODELS=["gemini-2.5-flash-lite"]
GEMINI_MAX_RETRIES=2
# JSON-encoded list. In production set to your deployed frontend URL.
CORS_ORIGINS=["http://localhost:5173"]
SECRET_KEY=change_me_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL the OAuth providers should redirect back to.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
